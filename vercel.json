{
  "outputDirectory": "dist",
  "buildCommand": "npm run build",
  "headers": [
    {
      "source": "/calendar/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(self \"https://8x8.vc\"), geolocation=(), payment=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://s3.tradingview.com https://apis.google.com https://8x8.vc https://www.gstatic.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.tradingview.com https://lh3.googleusercontent.com https://*.8x8.vc; frame-src 'self' https://*.tradingview.com https://www.tradingview-widget.com https://pointlab-96310.firebaseapp.com https://accounts.google.com https://docs.google.com https://8x8.vc https://*.8x8.vc; connect-src 'self' https://api.allorigins.win https://api.codetabs.com https://query1.finance.yahoo.com https://query2.finance.yahoo.com https://www3.nhk.or.jp https://*.googleapis.com wss://*.googleapis.com https://apis.google.com https://*.8x8.vc wss://*.8x8.vc https://finnhub.io https://*.sentry.io; font-src 'self'; object-src 'none'; base-uri 'self'; worker-src 'self' blob:; form-action 'self'; upgrade-insecure-requests;"
        },
        {
          "key": "X-Permitted-Cross-Domain-Policies",
          "value": "none"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/hakaseAI", "destination": "https://hakase-ai.vercel.app", "permanent": false },
    { "source": "/hakaseAI/(.*)", "destination": "https://hakase-ai.vercel.app/$1", "permanent": false }
  ],
  "functions": {
    "api/create-booking.js": { "memory": 128 },
    "api/cancel-booking.js": { "memory": 128 },
    "api/send-booking-email.js": { "memory": 128 },
    "api/send-booking-push.js": { "memory": 128 },
    "api/booking-ics.js": { "memory": 128 },
    "api/cron-push-notifications.js": { "memory": 256 },
    "api/notify-data-ready.js": { "memory": 256 }
  },
  "crons": [
    {
      "path": "/api/cron-push-notifications",
      "schedule": "30 3 * * *"
    }
  ],
  "rewrites": [
    { "source": "/__/auth/:path*", "destination": "https://pointlab-96310.firebaseapp.com/__/auth/:path*" },
    { "source": "/calendar/:path*", "destination": "/calendar/index.html" },
    { "source": "/stock-calendar/(.*)", "destination": "/calendar/index.html" },
    { "source": "/stock-calendar", "destination": "/calendar/index.html" }
  ]
}
