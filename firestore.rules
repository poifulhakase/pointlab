rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /slots/{slotId} {
      allow read: if true;
      // 書き込みは管理者のみ。予約作成/キャンセル時の isBooked 更新はサーバー API
      // （Admin SDK・ルールをバイパス）が行う。以前の「認証ユーザーは isBooked のみ更新可」は
      // 任意スロットの予約状態を改ざんできる穴だったため廃止（★2026-05-30）。
      allow write: if request.auth != null
        && request.auth.token.email == 'sushi.ramen.unajyu@gmail.com';
    }

    // レート制限カウンタ。サーバー（Admin SDK）専用。クライアントからは読み書き不可。
    match /rateLimits/{id} {
      allow read, write: if false;
    }

    match /pushSubscriptions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /community_members/{email} {
      // 本人確認（メールアドレスのURLデコード後と一致）または管理者のみ読み取り可
      allow read: if request.auth != null
        && (request.auth.token.email == 'sushi.ramen.unajyu@gmail.com'
            || request.auth.token.email.lower() == email.lower());
      // 書き込みは管理者のみ
      allow write: if request.auth != null
        && request.auth.token.email == 'sushi.ramen.unajyu@gmail.com';
    }

    // アプリ全体のメンテナンスモード状態。未ログイン含む全員が読み取り可、書き込みは管理者のみ。
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == 'sushi.ramen.unajyu@gmail.com';
    }

    match /bookings/{bookingId} {
      allow read: if request.auth != null
        && (request.auth.token.email == 'sushi.ramen.unajyu@gmail.com'
            || resource.data.userId == request.auth.uid);
      // 正規の予約作成はサーバー API（Admin SDK・ルールをバイパス）経由。
      // クライアント直書きは多層防御として厳格化: 本人の userId・status=pending・必須フィールドを要求。
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll(['userId', 'slotId', 'date', 'startTime', 'status']);
      allow update: if request.auth != null
        && (request.auth.token.email == 'sushi.ramen.unajyu@gmail.com'
            || resource.data.userId == request.auth.uid);
    }

  }
}
